---
import { Picture } from "@astrojs/image/components";
import heroImage from "assets/hero.png";
---

<main
  class="grid lg:grid-cols-2 place-items-center pt-16 pb-8 md:pt-12 md:pb-24">
  <div class="py-6 md:order-1 hidden md:block">
    <Picture
      class="rounded-xl"
      src={heroImage}
      alt="Astronaut in the air"
      widths={[200, 400, 600]}
      aspectRatio="4:3"
      sizes="(max-width: 800px) 100vw, 620px"
      loading="eager"
      format="avif"
    />
  </div>
  <div class="pr-4">
    <h1
      class="text-5xl lg:text-6xl xl:text-7xl font-bold lg:tracking-tight xl:tracking-tighter">
      About me
    </h1>
    <p class="text-lg mt-4 text-slate-600 max-w-xl">
      I'm a software engineer and content creator who builds mostly with Go. I
      do developer relations at @charmcli which is top tier ~fabulous~. I hack
      on open source projects (my own, Charm's, and others) in public on my
      Twitch channel. I also have a YouTube channel where I post more curated
      content on what I'm learning. I love long form content because I resent
      how social media platforms can feel like a highlight reel of people's
      lives, when in reality, we all struggle, especially when coding (heh).
    </p>
  </div>
</main>
